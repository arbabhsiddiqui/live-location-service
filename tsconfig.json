{
  "compilerOptions": {
    // File Layout
     "typeRoots": ["./src/types", "./node_modules/@types"],
    "rootDir": "./src",
    "outDir": "./dist",

    // Node Environment
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    // "types": ["node"],

    // Output
    "sourceMap": true,

    // Type Safety
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Interop
    "esModuleInterop": true,

    // Optional
    "skipLibCheck": true
  },
  "exclude": ["drizzle.config.ts", "node_modules"]
}